{
  "name": "@rnto1/apple-notes-mcp",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "bin": {
    "apple-notes-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "postbuild": "node scripts/ensure-shebang.js",
    "changeset": "changeset",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "test": "npm run build && node --test",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm test",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "os": [
    "darwin"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.8.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "description": "MCP server for Apple Notes on macOS (local stdio)",
  "keywords": [
    "mcp",
    "model context protocol",
    "apple",
    "notes",
    "macos",
    "cli",
    "renatoaraujo"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/renatoaraujo/apple-notes-mcp.git"
  }
}
