{
  "name": "@rnto1/apple-notes-mcp",
  "version": "0.2.2",
  "private": false,
  "type": "module",
  "bin": {
    "apple-notes-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/ensure-shebang.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "activate:create": "tsx scripts/activate-and-create.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "test": "node --test",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm test",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "description": "MCP server for Apple Notes on macOS (local stdio)",
  "keywords": [
    "mcp",
    "model context protocol",
    "apple",
    "notes",
    "macos",
    "cli",
    "renatoaraujo"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/renatoaraujo/apple-notes-mcp.git"
  }
}
